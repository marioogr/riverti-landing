---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
        <span>Riverti</span>
      </a>
      <p>Productos y sistemas de datos para equipos que necesitan criterio metodológico, continuidad operativa y una capa técnica defendible.</p>
    </div>

    <nav class="footer-nav" aria-label="Pie de página">
      <div>
        <h4>Compañía</h4>
        <ul>
          <li><a href="#que-hace">Qué hacemos</a></li>
          <li><a href="#enfoque">Enfoque</a></li>
          <li><a href="#capacidades">Capacidades</a></li>
        </ul>
      </div>
      <div>
        <h4>Productos</h4>
        <ul>
          <li><a href="/maipo">Maipo</a></li>
        </ul>
      </div>
      <div>
        <h4>Contacto</h4>
        <ul>
          <li><a href="mailto:hola@riverti.com">hola@riverti.com</a></li>
          <li><a href="#contacto">Agendar conversación</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="container footer-bottom">
    <span>© {year} Riverti</span>
    <span>Datos, producto y analítica</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding-top: 3.5rem;
    padding-bottom: 2rem;
    margin-top: 3rem;
    background: transparent;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 3rem;
    align-items: start;
  }

  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--fg);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .brand-mark {
    position: relative;
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0));
    overflow: hidden;
  }

  .brand-mark span {
    position: absolute;
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 234, 238, 0.7), transparent);
  }

  .brand-mark span:first-child {
    width: 110%;
    transform: rotate(44deg);
    top: 48%;
    left: -5%;
  }

  .brand-mark span:last-child {
    width: 80%;
    transform: rotate(-44deg);
    top: 48%;
    left: 10%;
  }

  .footer-brand p {
    font-size: 0.9375rem;
    max-width: 40ch;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-nav h4 {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-dim);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-nav a {
    font-size: 0.9375rem;
    color: var(--fg-muted);
  }

  .footer-nav a:hover {
    color: var(--fg);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-size: 0.8125rem;
    color: var(--fg-dim);
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.5rem;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
    }
  }
</style>
