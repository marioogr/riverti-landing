---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Maipo — Monitoreo de precios e inflación preliminar"
  description="Maipo es la plataforma de Riverti para monitoreo de precios e inflación preliminar."
>
  <Header brand="maipo" />

  <main id="main-content">
    <section class="section maipo-hero">
      <div class="container">
        <p class="eyebrow reveal">Producto / Maipo</p>
        <h1 class="reveal" style="--d:60ms">
          Monitoreo de precios<br />e inflación preliminar.
        </h1>
        <p class="lead reveal" style="--d:140ms">
          Maipo recolecta y normaliza precios desde múltiples canales para
          entregar señales tempranas de variación, antes de que aparezcan en
          la cifra oficial.
        </p>
        <div class="actions reveal" style="--d:220ms">
          <a href="mailto:hola@riverti.com?subject=Demo%20Maipo" class="btn btn-primary">
            Solicitar demo
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a href="/" class="btn btn-ghost">Volver a Riverti</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .maipo-hero {
    padding-top: clamp(8rem, 16vh, 11rem);
    padding-bottom: clamp(6rem, 14vh, 9rem);
  }
  .eyebrow { margin-bottom: 1.25rem; }
  h1 { margin-bottom: 1.5rem; max-width: 12ch; }
  .lead { margin-bottom: 2.25rem; max-width: 62ch; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .reveal { transition-delay: var(--d, 0ms); }
  @media (max-width: 640px) {
    h1 br { display: none; }
  }
</style>
